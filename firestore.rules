rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Usernames Collection (Uniqueness Map) ---
    match /usernames/{username} {
      function isValidUsername(data) {
        return data.keys().hasAll(['uid', 'email'])
            && data.uid is string
            && data.email is string
            && (data.get('securityQuestion', null) == null || (data.securityQuestion is string && data.securityQuestion.size() <= 200))
            && (data.get('hashedAnswer', null) == null || (data.hashedAnswer is string && data.hashedAnswer.size() <= 100));
      }
      
      allow get: if true;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid && isValidUsername(incoming());
      allow update: if isSignedIn() && existing().uid == request.auth.uid && incoming().uid == request.auth.uid && isValidUsername(incoming());
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return (data.get('uid', null) == null || data.get('uid', '') == request.auth.uid)
            && (data.get('name', null) == null || (data.get('name', '') is string && data.get('name', '').size() <= 100))
            && (data.get('email', null) == null || (data.get('email', '') is string && data.get('email', '').size() <= 100))
            && (data.get('age', null) == null || (data.get('age', 0) is number))
            && (data.get('dob', null) == null || (data.get('dob', '') is string && data.get('dob', '').size() <= 30))
            && (data.get('username', null) == null || (data.get('username', '') is string && data.get('username', '').size() <= 100))
            && (data.get('securityQuestion', null) == null || (data.get('securityQuestion', '') is string && data.get('securityQuestion', '').size() <= 200))
            && (data.get('securityAnswer', null) == null || (data.get('securityAnswer', '') is string && data.get('securityAnswer', '').size() <= 100))
            && (data.get('reminderEnabled', null) == null || (data.get('reminderEnabled', false) is bool))
            && (data.get('reminderTime', null) == null || (data.get('reminderTime', '') is string && data.get('reminderTime', '').size() <= 10))
            && (data.get('wellnessPartnerName', null) == null || (data.get('wellnessPartnerName', '') is string && data.get('wellnessPartnerName', '').size() <= 100))
            && (data.get('wellnessPartnerEmail', null) == null || (data.get('wellnessPartnerEmail', '') is string && data.get('wellnessPartnerEmail', '').size() <= 100))
            && (data.get('locale', null) == null || (data.get('locale', '') is string && data.get('locale', '').size() <= 20))
            && (data.get('theme', null) == null || (data.get('theme', '') is string && data.get('theme', '').size() <= 20))
            && (data.get('lastState', null) == null || (data.get('lastState', '') is string && data.get('lastState', '').size() <= 100))
            && (data.get('baselineAnswers', null) == null || (data.get('baselineAnswers', {}) is map))
            && (data.get('baselineScore', null) == null || (data.get('baselineScore', 0) is number))
            && (data.get('createdAt', null) == null || (data.get('createdAt', request.time) is timestamp))
            && (data.get('updatedAt', null) == null || (data.get('updatedAt', request.time) is timestamp));
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && incoming().keys().hasAll(['uid', 'email'])
                    && isValidUser(incoming()) 
                    && (incoming().get('createdAt', request.time) == request.time);
      allow update: if isOwner(userId)
                    && isValidUser(incoming())
                    && (incoming().get('uid', null) == existing().get('uid', null))
                    && (incoming().get('email', null) == existing().get('email', null))
                    && (incoming().get('createdAt', null) == existing().get('createdAt', null))
                    && (incoming().diff(existing()).affectedKeys().hasOnly([
                      'uid', 'email', 'name', 'age', 'dob', 'lastState', 'updatedAt', 'createdAt',
                      'username', 'securityQuestion', 'securityAnswer',
                      'reminderEnabled', 'reminderTime',
                      'wellnessPartnerName', 'wellnessPartnerEmail',
                      'locale', 'theme', 'baselineAnswers', 'baselineScore'
                    ]));
    }

    // --- Mood Logs ---
    match /users/{userId}/mood_logs/{logId} {
      function isValidMood(data) {
        return data.keys().hasAll(['userId', 'mood', 'timestamp'])
            && data.userId == userId
            && data.mood in ['Happy', 'Hopeful', 'Calm', 'Neutral', 'Sad', 'Tired', 'Lonely', 'Dissociated', 'Stressed', 'Anxious', 'Angry', 'Fearful']
            && (data.get('note', '') is string && data.get('note', '').size() <= 1000)
            && (data.get('sleepScore', 0) is number)
            && (data.get('energyScore', 0) is number)
            && (data.get('moods', []) is list);
      }

      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMood(incoming()) && incoming().timestamp == request.time;
      allow delete: if isOwner(userId);
      // Mood logs are immutable usually, but let's allow delete if they want to remove history
    }

    // --- Symptom Logs ---
    match /users/{userId}/symptom_logs/{logId} {
      function isValidSymptom(data) {
        return data.keys().hasAll(['userId', 'symptoms', 'timestamp'])
            && data.userId == userId
            && data.symptoms is list && data.symptoms.size() <= 20
            && (data.symptoms.size() == 0 || data.symptoms[0] is string);
      }

      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSymptom(incoming()) && incoming().timestamp == request.time;
      allow delete: if isOwner(userId);
    }

    // --- Safety Contacts ---
    match /users/{userId}/safety_contacts/{contactId} {
      function isValidSafetyContact(data) {
        return data.keys().hasAll(['name', 'phone', 'relationship', 'createdAt'])
            && data.name is string && data.name.size() <= 100
            && data.phone is string && data.phone.size() <= 100
            && data.relationship is string && data.relationship.size() <= 100
            && data.createdAt is string && data.createdAt.size() <= 50
            && (data.get('email', '') is string && data.get('email', '').size() <= 100);
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSafetyContact(incoming());
      allow delete: if isOwner(userId);
    }

    // --- Doctor Appointments ---
    match /users/{userId}/doctor_appointments/{appointmentId} {
      function isValidDoctorAppointment(data) {
        return data.keys().hasAll(['doctorName', 'dateTime', 'completed', 'createdAt'])
            && data.doctorName is string && data.doctorName.size() <= 100
            && data.dateTime is string && data.dateTime.size() <= 100
            && data.completed is bool
            && (data.get('discussedNotes', '') is string && data.get('discussedNotes', '').size() <= 1000)
            && (data.get('clinicalAdvice', '') is string && data.get('clinicalAdvice', '').size() <= 1000)
            && data.createdAt is string && data.createdAt.size() <= 50;
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidDoctorAppointment(incoming());
      allow delete: if isOwner(userId);
    }

    // --- Medication Reminders ---
    match /users/{userId}/medication_reminders/{reminderId} {
      function isValidMedicationReminder(data) {
        return data.keys().hasAll(['medicationName', 'dosage', 'timeOfDay', 'enabled'])
            && data.medicationName is string && data.medicationName.size() <= 100
            && data.dosage is string && data.dosage.size() <= 100
            && data.timeOfDay is string && data.timeOfDay.size() <= 10
            && data.enabled is bool;
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMedicationReminder(incoming());
      allow update: if isOwner(userId) && isValidMedicationReminder(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['enabled']);
      allow delete: if isOwner(userId);
    }

    // --- Test Connection Path ---
    match /test/connection {
      allow read: if true;
    }
  }
}
